{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "desktop/target/**",
    "**/dist/**",
    "**/node_modules/**"
  ],
  "ignoreWorkspaces": ["packages/demos"],
  "ignoreUnresolved": [
    "~icons/*",
    "/packages/core/src/text/fonts.ts",
    "/src/app/editor/fonts/index.ts",
    "#core/*"
  ],
  "ignoreBinaries": ["cmd.exe", "figma-use", "identify", "magick", "open", "osascript"]
}
